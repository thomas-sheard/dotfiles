## things i want for sway:
# tabbed / stacked borders to be complete on the top edge
# persistent direction indicator even after a split

# startup
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec mako
exec /home/thomas/bin/bash/gammastep_toggle.sh -t 4500

include ./profile

exec_always xrandr --output XWAYLAND0 --primary

#super key
set $mod Mod4

# terminal 
#set $term foot
set $term foot --working-directory=$(swaycwd)

# launcher
set $menu tofi
set $drun tofi-drun | xargs swaymsg exec --

# vimlike direction modifiers
set $left h
set $down j
set $up k
set $right l

# general

font pango:IosevkaVariant 10
output * bg /home/thomas/.config/wallpapers/sage_wallpaper.jpg fill

output eDP-1 {
  resolution 1920x1080 position 0,0
}


# borders

default_border pixel 1
gaps inner 0
gaps outer 0

smart_gaps on
smart_borders on

# class                 border  bg      text    indicator child_border
client.focused          #9CAF88 #282c34 #ABB2bf #e06c74   #9CAF88
client.focused_inactive #9CAF88 #282c34 #ABB2bf #e06c74   #282c34
client.unfocused        #282c34 #282c34 #ABB2bf #e06c74   #282c34
#client.background #9CAF88

bar {
  position top
    swaybar_command waybar
}

# devices

focus_follows_mouse always

for_window [shell="xwayland"] title_format "[XWayland] %title"

#for_window [class="steam"] input type:touchpad dwt disabled

input type:touchpad {
  accel_profile flat
    pointer_accel 0.5
    scroll_factor 0.2

    dwt disabled
    tap enabled
    drag disabled
    natural_scroll enabled
}

input type:keyboard {
  xkb_options ctrl:nocaps,altwin:swap_alt_win
  repeat_delay 300
  repeat_rate 30 
}

# key bindings

# new terminal
bindsym $mod+Return exec $term

# toggle tofi (launcher)
bindsym $mod+space exec pkill tofi-drun || tofi-drun | xargs swaymsg exec --

# kill focused window
bindsym $mod+q kill

# left mouse button for dragging.
floating_modifier $mod normal

# reload the configuration file
bindsym $mod+r reload

# she close on my lid till i switch
bindswitch --locked lid:on output eDP-1 disable
bindswitch --locked lid:off output eDP-1 enable

# exit sway (logs you out of your Wayland session)
bindsym $mod+Shift+e exec swaynag -t warning -m 'Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'

# nav

bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Control+$left move left
bindsym $mod+Control+$down move down
bindsym $mod+Control+$up move up
bindsym $mod+Control+$right move right

#bindsym $mod+o split toggle
workspace_layout default
default_orientation horizontal
bindsym $mod+i split v
bindsym $mod+o split h

bindsym $mod+e layout splith
bindsym $mod+w layout tabbed
bindsym $mod+s layout stacking

bindsym $mod+u layout toggle split

# toggle fullscreen
bindsym $mod+f fullscreen

# toggle floating
bindsym $mod+v floating toggle

# move focus to the parent container
## THIS HAS A LOT OF POTENTIAL!!!
bindsym $mod+Equal focus parent
bindsym $mod+Minus focus child

# swapping workspaces

bindsym $mod+Tab workspace back_and_forth

bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

bindsym $mod+bracketright workspace next
bindsym $mod+bracketleft workspace prev

# moving windows

bindsym $mod+Control+Tab move container to workspace back_and_forth

bindsym $mod+Control+1 floating disable, move container to workspace 1
bindsym $mod+Control+2 floating disable, move container to workspace 2
bindsym $mod+Control+3 floating disable, move container to workspace 3
bindsym $mod+Control+4 floating disable, move container to workspace 4
bindsym $mod+Control+5 floating disable, move container to workspace 5
bindsym $mod+Control+6 floating disable, move container to workspace 6
bindsym $mod+Control+7 floating disable, move container to workspace 7
bindsym $mod+Control+8 floating disable, move container to workspace 8
bindsym $mod+Control+9 floating disable, move container to workspace 9
bindsym $mod+Control+0 floating disable, move container to workspace 10

bindsym $mod+Control+bracketright move container to workspace next
bindsym $mod+Control+bracketleft move container to workspace prev

# scratchpad

bindsym $mod+grave scratchpad show
bindsym $mod+Control+grave floating enable, resize set width 1400 height 900, move scratchpad
#bindsym $mod+Control+grave move container to scratchpad

# resizing

bindsym $mod+Shift+$left resize grow width 10px
bindsym $mod+Shift+$right resize shrink width 10px
bindsym $mod+Shift+$down resize grow height 10px
bindsym $mod+Shift+$up resize shrink height 10px

# F1-F4

bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

# F5-F8

bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86Display exec /home/thomas/bin/bash/gammastep_toggle.sh -t 4500
#bindsym --locked XF86WLAN exec # swaylock?

# F9-F12

#bindsym --locked XF86Messenger exec /home/thomas/bin/bash/player_popup.sh
bindsym --locked XF86PickupPhone exec playerctl --player=playerctld previous
bindsym --locked XF86HangupPhone exec playerctl --player=playerctld next
bindsym --locked XF86Favorites exec playerctl --player=playerctld play-pause

# screenshot + screenshot to clipboard
# FIXME: currently saves to ~ instead of ~/Pictures, which is annoying

bindsym Print exec grim -g "$(slurp)" 
bindsym Control+Print exec grim -g "$(slurp -d)" - | wl-copy

for_window [app_id="zenity"] floating enable

bindsym $mod+Print exec bash -c 'TEMP_FILE=$(mktemp /tmp/screenshot_XXXXXX.png); grim -g "$(slurp)" "$TEMP_FILE" && TARGET=$(zenity --file-selection --save --confirm-overwrite --filename="$HOME/screenshot_$(date +%Y%m%d_%H%M%S).png"); if [ ! -z "$TARGET" ]; then mv "$TEMP_FILE" "$TARGET"; else rm "$TEMP_FILE"; fi'

#bindsym $mod+Print exec bash -c 'TARGET=$(zenity --file-selection --save --confirm-overwrite --filename="$HOME/screenshot_$(date +%Y%m%d_%H%M%S).png"); [ ! -z "$TARGET" ] && grim -g "$(slurp)" "$TARGET"'

# gestures

bindgesture swipe:right workspace prev
bindgesture swipe:left workspace next

include /etc/sway/config.d/*
