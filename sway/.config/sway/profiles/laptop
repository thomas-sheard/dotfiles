exec_always notify-send "Using laptop configuration" "Change in .config/sway/set_profile"

exec /home/thomas/bin/bash/gammastep_toggle.sh -t 4500

font pango:IosevkaVariant2 10

output eDP-1 {
  resolution 1920x1080 position 0,0
}


input type:keyboard {
  xkb_options ctrl:nocaps,altwin:swap_alt_win
}

input type:touchpad {
  accel_profile flat
    pointer_accel 0.5
    scroll_factor 0.2

    dwt disabled
    tap enabled
    drag disabled
    natural_scroll enabled
}

# she close on my lid till i switch
bindswitch --locked lid:on output eDP-1 disable
bindswitch --locked lid:off output eDP-1 enable

# F1-F4

bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

# F5-F8

bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86Display exec /home/thomas/bin/bash/gammastep_toggle.sh -t 4500
#bindsym --locked XF86WLAN exec # swaylock?

# F9-F12

#bindsym --locked XF86Messenger exec /home/thomas/bin/bash/player_popup.sh
bindsym --locked XF86PickupPhone exec playerctl --player=playerctld previous
bindsym --locked XF86HangupPhone exec playerctl --player=playerctld next
bindsym --locked XF86Favorites exec playerctl --player=playerctld play-pause

# touchpad gestures

bindgesture swipe:right workspace prev
bindgesture swipe:left workspace next
